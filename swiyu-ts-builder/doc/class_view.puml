@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "generic-java-lib" {

  package "swiyu-ts-builder" {

    class TrustStatementValidationException <<RuntimeException>> {
      + TrustStatementValidationException(message: String)
    }

    abstract class AbstractTrustStatementBuilder<T extends AbstractTrustStatementBuilder<T>> {
      # product: TrustStatementJwt
      # {abstract} self(): T
      # setTypHeader(typ: String)
      # validateRequired(claimKey: String, errorMessage: String)
      # validateDid(did: String, claimName: String)
      # validateUuidV4(uuid: String, claimName: String)
      # validateMaxLength(value: String, max: int, claimName: String)
      # localizedKey(baseName: String, locale: String): String
      + withKid(kid: String): T
      + withSubject(subject: String): T
      + withValidity(issuedAt: Instant, expiresAt: Instant): T
      + withValidity(issuedAt: Instant, notBefore: Instant, expiresAt: Instant): T
      + withStatus(idx: int, uri: String): T
      + build(): TrustStatementJwt
    }

    class IdTsBuilder {
      + addEntityName(name: String): IdTsBuilder
      + addEntityName(locale: String, name: String): IdTsBuilder
      + withIsStateActor(isStateActor: Boolean): IdTsBuilder
      + addRegistryId(type: String, value: String): IdTsBuilder
      + build(): TrustStatementJwt
    }

    class VqPsBuilder {
      + withJti(uuid: String): VqPsBuilder <<validates UUIDv4>>
      + addPurposeName(name: String): VqPsBuilder <<max 50>>
      + addPurposeName(locale: String, name: String): VqPsBuilder <<max 50>>
      + addPurposeDesc(desc: String): VqPsBuilder <<max 500>>
      + addPurposeDesc(locale: String, desc: String): VqPsBuilder <<max 500>>
      + withRequest(scope: String, dcqlQuery: Map<String,Object>): VqPsBuilder <<validates DCQL>>
      + build(): TrustStatementJwt
    }

    class PvaTsBuilder {
      + withJti(uuid: String): PvaTsBuilder <<validates UUIDv4>>
      + withAuthorizedFields(fields: List<String>): PvaTsBuilder <<not empty>>
      + build(): TrustStatementJwt
    }

    class PiaTsBuilder {
      + withCanIssue(vct: String, locale: String, vctName: String, reason: String): PiaTsBuilder
      + build(): TrustStatementJwt
    }

    note right of PiaTsBuilder
      can_issue is a single JSON object.
      vct_name: max 500 chars, localizable.
      reason: optional, max 50 chars, localizable.
    end note

    class PiTlsBuilder {
      + withJti(uuid: String): PiTlsBuilder <<validates UUIDv4>>
      + withVctValues(vctValues: List<String>): PiTlsBuilder <<not empty>>
      + build(): TrustStatementJwt
    }

    class NcTlsBuilder {
      + addNonCompliantActor(actorBuilder: NonCompliantActorBuilder): NcTlsBuilder
      + build(): TrustStatementJwt
    }

    class "NcTlsBuilder.NonCompliantActorBuilder" as NonCompliantActorBuilder {
      + NonCompliantActorBuilder(did: String, flaggedAt: String, reason: String) <<validates RFC3339>>
      + addReason(locale: String, reason: String): NonCompliantActorBuilder
    }

    class TrustStatementJwt {
      - header: Map<String, String>
      - payload: Map<String, Object>
      ~ addHeaderClaim(key: String, value: String)
      ~ addPayloadClaim(key: String, value: Object)
      + getHeader(): Map<String, String>
      + getPayload(): Map<String, Object>
      + getPayloadToSign(): String
    }

    AbstractTrustStatementBuilder <|-- IdTsBuilder
    AbstractTrustStatementBuilder <|-- VqPsBuilder
    AbstractTrustStatementBuilder <|-- PvaTsBuilder
    AbstractTrustStatementBuilder <|-- PiaTsBuilder
    AbstractTrustStatementBuilder <|-- PiTlsBuilder
    AbstractTrustStatementBuilder <|-- NcTlsBuilder

    NcTlsBuilder +-- NonCompliantActorBuilder

    AbstractTrustStatementBuilder -> TrustStatementJwt : encapsulates and populates
    AbstractTrustStatementBuilder .> TrustStatementValidationException : throws
  }

  package "swiyu-jws-signature-service" {

    interface JWSSigner <<Strategy>> {
      + sign(payload: String): String
    }

  }

}

package "Tergum" {

  class TergumTrustService {
    - signerFactory: TergumSigningService
    + constructIdentityTrustStatement(data: IdTsRequest): String
    + constructVerificationQueryStatement(data: VqPsRequest): String
  }

  class TergumSigningService <<Factory>> {
    + createSigner(): JWSSigner
  }
}

' Dependencies
TergumTrustService ..> IdTsBuilder : uses for idTS
TergumTrustService ..> VqPsBuilder : uses for vqPS
TergumTrustService --> TergumSigningService : uses
TergumSigningService ..> JWSSigner : provides

@enduml